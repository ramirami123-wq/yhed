er\" aria-live=\"polite\">\n      <div class=\"sale-timer__box\" id=\"st-hours\">00<\/div>\n      <div class=\"sale-timer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-mins\">00<\/div>\n      <div class=\"sale-timer__colon\">:<\/div>\n      <div class=\"sale-timer__box\" id=\"st-secs\">00<\/div>\n    <\/div>\n  <\/div>\n\n  <script>\n    (function () {\n      const durationHours = 12; \/\/ change if needed\n      const endAt = Date.now() + durationHours * 60 * 60 * 1000;\n\n      const h = document.getElementById(\"st-hours\");\n      const m = document.getElementById(\"st-mins\");\n      const s = document.getElementById(\"st-secs\");\n\n      const pad = n => String(n).padStart(2, \"0\");\n\n      function update(){\n        let diff = endAt - Date.now();\n        if(diff < 0) diff = 0;\n\n        const total = Math.floor(diff \/ 1000);\n        h.textContent = pad(Math.floor(total \/ 3600));\n        m.textContent = pad(Math.floor((total % 3600) \/ 60));\n        s.textContent = pad(total % 60);\n\n        if(diff === 0) clearInterval(timer);\n      }\n\n      update();\n      const timer = setInterval(update, 1000);\n    })();\n  <\/script>\n<\/section>"}},"liquid_WqHpzt":{"type":"liquid","disabled":true,"settings":{"liquid":"<div style=\"padding: 12px; text-align: left; background-color: #f9f9f9; font-size: 15px; border-radius: 12px; margin-top: 10px; margin-bottom: 10px; line-height: 1.6;\">\n<span style=\"font-weight: bold;\">✨ Spacious & Organized<\/span> – Keep all your cosmetics, skincare, and essentials neatly arranged in one place.<br><br>\n<span style=\"font-weight: bold;\">🧳 Travel-Ready Design<\/span> – Lightweight and compact, perfect for daily use, trips, or on-the-go touch-ups.<br><br>\n<span style=\"font-weight: bold;\">💖 Stylish & Durable<\/span> – Designed by Nazzemni to combine elegance with long-lasting quality for everyday convenience.\n<\/div>"}},"variant_picker":{"type":"variant_picker","settings":{"hide_sold_out_variants"